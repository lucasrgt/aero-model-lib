# Chunk-baked showcase mesh (Aero_MeshChunkBaker — v3.0).
# Stair-stepped pyramid: three stacked boxes that taper from base to tip,
# distinct from vanilla cubes so the player can spot which blocks are
# chunk-baked vs. BE-rendered in the stress test world.
#
# No named groups — every triangle lands in model.groups so the chunk
# baker can pre-bake them at registration time.
#
# UVs are 0..1 over each face; the baker remaps them into the tile
# coordinates of whatever atlas index the registration call passes.
#
# Face winding NOTE (v3.0.x fix): vanilla chunk render runs with
# GL_CULL_FACE enabled (glFrontFace=GL_CW), opposite of modellib's BE
# render context which leaves cull disabled. OBJ faces here use CW
# winding from outside POV so they survive the chunk-render cull.

# UV corners
vt 0 0
vt 1 0
vt 1 1
vt 0 1

# Bottom block (large): 0.1..0.9 X/Z, 0.0..0.3 Y
v 0.1 0.0 0.1
v 0.9 0.0 0.1
v 0.9 0.0 0.9
v 0.1 0.0 0.9
v 0.1 0.3 0.1
v 0.9 0.3 0.1
v 0.9 0.3 0.9
v 0.1 0.3 0.9

# Middle block: 0.25..0.75 X/Z, 0.3..0.6 Y
v 0.25 0.3 0.25
v 0.75 0.3 0.25
v 0.75 0.3 0.75
v 0.25 0.3 0.75
v 0.25 0.6 0.25
v 0.75 0.6 0.25
v 0.75 0.6 0.75
v 0.25 0.6 0.75

# Top block: 0.4..0.6 X/Z, 0.6..0.85 Y
v 0.4 0.6  0.4
v 0.6 0.6  0.4
v 0.6 0.6  0.6
v 0.4 0.6  0.6
v 0.4 0.85 0.4
v 0.6 0.85 0.4
v 0.6 0.85 0.6
v 0.4 0.85 0.6

# Bottom block faces — windings reversed from previous version so the
# chunk-render context's GL_CULL_FACE doesn't drop them.
f 8/4 7/3 6/2 5/1
f 2/4 3/3 4/2 1/1
f 5/4 6/3 2/2 1/1
f 8/4 5/3 1/2 4/1
f 7/4 8/3 4/2 3/1
f 6/4 7/3 3/2 2/1

# Middle block (9..16)
f 16/4 15/3 14/2 13/1
f 10/4 11/3 12/2 9/1
f 13/4 14/3 10/2 9/1
f 16/4 13/3 9/2 12/1
f 15/4 16/3 12/2 11/1
f 14/4 15/3 11/2 10/1

# Top block (17..24)
f 24/4 23/3 22/2 21/1
f 18/4 19/3 20/2 17/1
f 21/4 22/3 18/2 17/1
f 24/4 21/3 17/2 20/1
f 23/4 24/3 20/2 19/1
f 22/4 23/3 19/2 18/1
