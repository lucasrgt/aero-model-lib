# Gradle / Loom build artifacts (StationAPI subproject)
stationapi/build/
stationapi/.gradle/
stationapi/.idea/
stationapi/*.iml
stationapi/run/

# Test runner output
tests/out/

# Release artifacts (built by scripts/release.sh)
dist/

# Compiled converter classes (Aero_Convert is recompiled on demand by tools/convert.sh)
tools/*.class

# IDE
*.iml
.idea/
.vscode/

# Loom test mod (stationapi/test) build + run artifacts
stationapi/test/build/
stationapi/test/.gradle/
stationapi/test/.idea/
stationapi/test/run/
stationapi/test/*.iml
# JFR profiles + repos that the benchmark/stress tasks land at the
# test project root when Loom doesn't resolve workingDir to run/.
stationapi/test/*.jfr
stationapi/test/jfr-*-repo/
stationapi/test/jfr-repo/

# Same exclusions for the test-bare sibling (StationAPI-only minimal mod).
stationapi/test-bare/build/
stationapi/test-bare/.gradle/
stationapi/test-bare/.idea/
stationapi/test-bare/run/
stationapi/test-bare/*.iml
stationapi/test-bare/*.jfr
stationapi/test-bare/jfr-*-repo/
stationapi/test-bare/jfr-repo/

# Moved unit-test runner output
modloader/tests/out/
modloader/tests/bench-out/
